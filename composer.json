{
    "name": "jorisnoo/craft-sidebar-relations",
    "description": "Adds nested element sources to the Craft CMS sidebar based on entry relations",
    "type": "craft-module",
    "license": "MIT",
    "keywords": ["craft", "cms", "craftcms", "sidebar", "relations", "navigation"],
    "authors": [
        {
            "name": "Joris Noordermeer",
            "email": "contact@noordermeer.ch"
        }
    ],
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0"
    },
    "require-dev": {
        "laravel/pint": ">=1.18.1"
    },
    "autoload": {
        "psr-4": {
            "Noo\\CraftSidebarRelations\\": "src/"
        }
    },
    "scripts": {
        "lint": "pint"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    }
}
